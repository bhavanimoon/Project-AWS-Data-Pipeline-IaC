# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude override files as they are usually used for local changes
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive variable files
*.tfvars
*.tfvars.json

# CLI configuration files
.terraformrc
terraform.rc

# Ignore Python cache
__pycache__/
*.pyc

# Ignore local Tests folder
Tests/

# Ignore vscode settings
.vscode/
settings.json


